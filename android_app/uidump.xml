="false" password="false" selected="false" bounds="[0,0][1440,2560]"><node index="0" text="" resource-id="" class="android.view.View" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][1440,2560]"><node index="0" text="" resource-id="" class="android.widget.ScrollView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="true" long-clickable="false" password="false" selected="false" bounds="[0,352][1440,2560]"><node index="0" text="1. 开始扫描" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,464][352,546]" /><node index="1" text="在首页点击「开始扫描」，选择包含 txt/md 文件的文件夹。应用会递归读取文件、解析书名与作者、并计算内容指纹（SHA-256）用于识别重复。" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,562][1376,766]" /><node index="2" text="2. 查看文库" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,814][352,896]" /><node index="3" text="扫描完成后进入文库，可按「全部 / 已标记」筛选，按时间、名称、大小排序，并支持搜索；合集模式下按书名聚合查看重复。列表过长时，屏幕右下角会出现「回到顶层 / 回到底层」悬浮按钮，快速跳转。" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,912][1376,1184]" /><node index="4" text="3. 标记重复" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,1232][352,1314]" /><node index="5" text="合集模式下点击右上角菜单「标记重复」：按 PC 端逻辑（同作者 + 纯数字进度，保留最大进度与最大文件）智能勾选待删的重复项；也可「按书名/作者相同标记」给文件加星标、「清除标记」取消。" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,1330][1376,1602]" /><node index="6" text="4. 选择并删除" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,1650][408,1732]" /><node index="7" text="勾选要删除的文件（合集模式下「标记重复」会自动勾选重复项），底部出现「删除选中」按钮，确认后由前台服务逐个删除并实时显示结果。" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,1748][1376,1952]" /><node index="8" text="5. 删除安全" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,2000][352,2082]" /><node index="9" text="删除通过系统 SAF 授权进行，删除前可在确认页取消勾选。删除后文件进入回收站（部分系统）或直接移除，请谨慎操作。" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,2098][1376,2302]" /><node index="10" text="6. 设置" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,2350][241,2432]" /><node index="11" text="可调整主题、配置关键词替换规则（文件名数据清洗）；支持导出已标记清单与清空本地数据。" resource-id="" class="android.widget.TextView" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[64,2448][1376,2560]" /></node><node index="1" text="" resource-id="" class="android.view.View" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,0][1440,352]"><node index="0" text="" resource-id="" class="android.view.View" package="com.filescanner.app.debug" content-desc="" checkable="false" checked="false" clickable="true" enabled="true" focusable="true" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[16,128][208,320]"><node index="0" text="" resource-id="" class="android.view.View" package="com.filescanner.app.debug" content-desc="返回" checkable="false" checked="false" clickable="false" enabled="true" focusable="fals
@Entry
@Component
struct Help {
  build() {
    Column() {
      Text('使用帮助')
        .fontSize(20)
        .fontWeight(FontWeight.Bold)
        .margin({ top: 24, bottom: 16 })
        .fontColor($r('app.color.text_primary'))

      Scroll() {
        Column({ space: 14 }) {
          this.section('1. 开始扫描',
            '在首页点击「开始扫描」，进入「扫描配置」列表：可新增配置（选择文件夹、文件类型、是否递归、排除文件夹），或从已有配置直接开始。应用会递归读取文件、并在扫描时同步解析文件名提取书名/作者/进度/来源，用于识别重复。文件名解析已能正确处理作者名的修订后缀（如「作者：Nnnr（【修】山海镜花 融共同人）」会提取作者为 Nnnr，并正确识别来源、进度、书名）。扫描结果保存在本机，不会上传。')
          this.section('2. 查看文库与筛选',
            '扫描完成后进入文库，会按「每次扫描」分出多个文库。在文库内可按「全部 / 已勾选 / 未勾选 / 已标记 / 未标记」筛选，按时间、名称、大小排序。列表/合集两种视图通过顶部按钮切换。')
          this.section('2.1 搜索与拼音搜索',
            '支持按书名、作者、文件名搜索。更强大的拼音搜索：输入拼音全拼（如 doupo）或首字母缩写（如 dpcq），即可搜到「斗破苍穹」等中文书名/作者名，不用切换到中文输入法即可快速定位目标。')
          this.section('2.2 文件内容预览',
            '在文库列表或文件详情点击文件即可进入「文件预览」，直接查看 txt 文本内容。预览页提供竖向（默认）和横向（顶部）两种滚动条模式，可在「设置 → 阅读设置」中切换。竖向模式下，右侧可拖动的滚动条，拖动滑块即可快速上下滑动浏览；横向模式下，顶部粗进度条可左右拖动快速定位阅读进度。触摸滚动条时会临时加粗方便操作，0.5 秒不操作恢复原样。内容较多时采用流式分批加载（默认仅读取前若干行，向下滚动到底部自动加载更多），并能自动识别 GBK / UTF-8 编码，避免大文件卡顿；滚动条仅在内容超出一屏时出现。')
          this.section('3. 分页浏览大库',
            '面对几万、十几万条数据，底部「分页导航条」帮助你逐页浏览：①「每页」输入框填每页条数，点「应用」生效；②「跳到」输入框填目标页码，点「跳转」直达该页；③「首页 / 上一页 / 下一页 / 末页」快速翻页。这样无需一次性加载全部数据，浏览更流畅。')
          this.section('4. 合集模式与合集设置',
            '合集模式按「书名」把同名文件聚合在一起，便于发现重复。点击右上角菜单「合集设置」可设置：合集内文件数量区间（最少~最多，留空表示不限）以及需要排除的合集书名。设置后只显示符合条件的合集。在合集视图中，每个合集的汇总卡片标题下会实时显示该合集「已勾选 X 个」，方便确认待删项的数量。')
          this.section('5. 勾选重复',
            '合集模式下点击「勾选重复」：在「同一文库内、按（作者 + 小说名）子分组」套用五则规则智能勾选待删重复项——① 完全相等去重：小说名+作者+大小+进度 四字段完全一致的多本中，保留最新一本，其余全部勾选；② 纯数字进度对比：同组内所有进度均为纯数字时，进度数字最大者不勾选，其余纯数字文件全部勾选；③ 含中文进度保护：进度含中文（如完结/连载）不勾选；④ 最大文件不勾选原则：同组内唯一文件大小最大者不勾选；⑤ 完结+N番外排序：进度匹配「完结+数字番外」的文件，按数字 N 排序，最大者不勾选。\n\n上述五则规则可在「设置」页的「勾选重复规则」中单独开启或关闭（默认全部启用）。你也可以「按书名/作者相同标记」给文件加星标。')
          this.section('6. 选择并删除',
            '勾选要删除的文件后，底部出现「删除」按钮，点击后先让你选择【仅删除记录】或【删除记录和源文件（不可恢复）】，确认后由服务逐个删除并实时显示结果；删除前在确认页仍可取消勾选。删除通过系统授权进行，请谨慎操作。建议在「设置」中先用「导出已标记清单」备份待删列表。')
          this.section('7. 设置',
            '在「设置」中可调整主题与全局字号（自动适配不同手机屏幕）；「阅读设置」可切换预览页的竖向/横向滚动条模式；配置「关键词替换」规则做文件名数据清洗（扫描阶段清洗文件名、解析阶段清洗书名/作者等）；「勾选重复规则」可分别开关六条去重规则（默认全部启用），关闭后「勾选重复」和删除操作不再使用该规则判断；支持导出已标记清单与清空本地数据。')
          this.section('8. 数据说明',
            '本应用纯本地运行，所有数据保存在应用私有目录，不上传任何服务器。删除文库仅清除数据库记录，不会删除原文件夹。所有扫描、解析、删除都在本机完成，数据与网络无关。')
        }
        .width('100%')
        .padding({ left: 16, right: 16, bottom: 24 })
      }
      .layoutWeight(1)
      .width('100%')
    }
    .width('100%')
    .height('100%')
    .backgroundColor($r('app.color.bg_page'))
  }

  @Builder
  section(title: string, body: string) {
    Column({ space: 6 }) {
      Text(title)
        .fontSize(16)
        .fontWeight(FontWeight.Medium)
        .fontColor($r('app.color.primary'))
      Text(body)
        .fontSize(14)
        .fontColor($r('app.color.text_secondary'))
        .lineHeight(20)
    }
    .alignItems(HorizontalAlign.Start)
    .width('100%')
  }
}
